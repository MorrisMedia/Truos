generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  passwordHash    String
  role            String   @default("member") // 'member' | 'staff'
  orgId           String?
  divisionId      String?
  orgRole         String? // null | 'owner' | 'admin' | 'manager' | 'learner'
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  emailSubscribed Boolean  @default(true)

  org             Organization?        @relation(fields: [orgId], references: [id])
  division        OrgDivision?         @relation("DivisionMembers", fields: [divisionId], references: [id])
  ledDivision     OrgDivision?         @relation("DivisionLead")
  progress        LessonProgress[]
  certificates    Certificate[]
  purchases       Purchase[]
  entitlements    CourseEntitlement[]
  codeRedemptions CompCodeRedemption[]
  emailLogs       EmailLog[]

  @@index([orgId])
  @@index([divisionId])
  @@map("truos_users")
}

model EmailLog {
  id         String   @id @default(cuid())
  userId     String?
  toEmail    String
  subject    String
  kind       String // 'welcome' | 'access_granted' | 'cert_earned' | 'broadcast' | 'code_redeemed' | 'org_invite' | 'org_nudge'
  providerId String?
  status     String // 'sent' | 'failed'
  error      String?
  sentAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([kind])
  @@index([sentAt])
  @@map("truos_email_log")
}

model Organization {
  id               String    @id @default(cuid())
  slug             String?   @unique
  name             String
  domains          String[]  @default([])
  primaryColor     String?
  logoUrl          String?
  trashTalk        String?
  trashTalkAt      DateTime?
  autoGrantAll     Boolean   @default(false)
  stripeCustomerId String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  members      User[]
  divisions    OrgDivision[]
  subscription Subscription?

  @@map("truos_orgs")
}

model OrgDivision {
  id          String    @id @default(cuid())
  orgId       String
  slug        String
  name        String
  color       String?
  emoji       String?
  leadUserId  String?   @unique
  trashTalk   String?
  trashTalkAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org     Organization @relation(fields: [orgId], references: [id])
  lead    User?        @relation("DivisionLead", fields: [leadUserId], references: [id])
  members User[]       @relation("DivisionMembers")

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("truos_org_divisions")
}

model Subscription {
  id                   String   @id @default(cuid())
  orgId                String   @unique
  stripeSubscriptionId String   @unique
  stripePriceId        String
  seats                Int
  status               String // 'active' | 'past_due' | 'canceled' | 'trialing'
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id])

  @@map("truos_subscriptions")
}

model Purchase {
  id                      String    @id @default(cuid())
  userId                  String
  courseIds               Int[]
  amount                  Int // cents
  currency                String    @default("usd")
  stripePaymentIntentId   String?   @unique
  stripeCheckoutSessionId String?   @unique
  status                  String // 'pending' | 'completed' | 'refunded'
  paidAt                  DateTime?
  createdAt               DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("truos_purchases")
}

model CourseEntitlement {
  id        String    @id @default(cuid())
  userId    String
  courseId  Int
  source    String // 'purchase' | 'comp_code' | 'manual_grant' | 'subscription'
  sourceId  String?
  grantedAt DateTime  @default(now())
  expiresAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, courseId, source])
  @@index([userId])
  @@map("truos_entitlements")
}

model CompCode {
  id         String    @id @default(cuid())
  code       String    @unique
  label      String?
  courseIds  Int[]
  maxUses    Int?
  uses       Int       @default(0)
  expiresAt  DateTime?
  createdBy  String
  createdAt  DateTime  @default(now())
  disabledAt DateTime?

  redemptions CompCodeRedemption[]

  @@map("truos_comp_codes")
}

model CompCodeRedemption {
  id         String   @id @default(cuid())
  codeId     String
  userId     String
  redeemedAt DateTime @default(now())

  code CompCode @relation(fields: [codeId], references: [id])
  user User     @relation(fields: [userId], references: [id])

  @@unique([codeId, userId])
  @@map("truos_code_redemptions")
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  courseId    Int
  moduleIdx   Int
  lessonIdx   Int
  completedAt DateTime @default(now())
  score       Int // 0-100

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, courseId, moduleIdx, lessonIdx])
  @@index([userId, courseId])
  @@map("truos_progress")
}

model Certificate {
  id               String   @id @default(cuid())
  userId           String
  courseId         Int
  issuedAt         DateTime @default(now())
  verificationHash String   @unique

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@map("truos_certificates")
}

model AffiliatePartner {
  id           String  @id @default(cuid())
  slug         String  @unique
  name         String
  heroImageUrl String?
  heroHeadline String?
  bio          String?

  couponCode           String @unique
  couponPercentOff     Int?
  couponAmountOffCents Int?
  bundlePriceCents     Int    @default(49500)

  revenueSharePct Int @default(30)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attributions AffiliateAttribution[]
  payouts      AffiliatePayout[]

  @@map("truos_affiliate_partners")
}

model AffiliateAttribution {
  id        String           @id @default(cuid())
  partnerId String
  partner   AffiliatePartner @relation(fields: [partnerId], references: [id])

  userId          String?
  purchaseId      String?
  stripeSessionId String  @unique

  amountCents Int
  shareCents  Int
  status      String
  paidAt      DateTime?
  refundedAt  DateTime?
  payoutId    String?

  createdAt DateTime @default(now())

  @@index([partnerId, createdAt])
  @@map("truos_affiliate_attributions")
}

model AffiliatePayout {
  id        String           @id @default(cuid())
  partnerId String
  partner   AffiliatePartner @relation(fields: [partnerId], references: [id])

  totalCents       Int
  attributionCount Int
  paidAt           DateTime
  method           String
  reference        String?
  notes            String?

  createdAt DateTime @default(now())

  @@index([partnerId, paidAt])
  @@map("truos_affiliate_payouts")
}
